bool isAnagram(char* s, char* t) {
   if(strlen(s)!=strlen(t)){
    return false;
   } 
  
   else{
    int ln=strlen(s);
    for(int i=0;i<ln-1;i++){
        for(int j=i+1;j<ln;j++){
            if(s[i]>s[j]){
                char temp=s[i];
                s[i]=s[j];
                s[j]=temp;
            }
        }
    }
    for(int i=0;i<strlen(t)-1;i++){
        for(int j=i+1;j<strlen(t);j++){
            if(t[i]>t[j]){
                char temp=t[i];
                t[i]=t[j];
                t[j]=temp;
            }
        }
    }
    if(strcmp(s,t)==0){
        return true;
    }
    else{
        return false;
    }
   }
    
}
